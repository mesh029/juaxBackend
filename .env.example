# Copy to .env and fill in — never commit .env
# Aiven Postgres (sslmode=require is mandatory)
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/defaultdb?sslmode=require

# Next.js — do not set NODE_ENV here; Next sets it per command
PORT=5080

# Auth (Phase 1)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
# Show OTP in API responses until SMS is integrated (default: true when NODE_ENV !== production)
OTP_DEV_MODE=true

# CORS — browser / Expo Web only (native Expo fetch ignores CORS)
# Local dev:
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081,http://localhost:5080
# Vercel production example (replace with your deployment URL):
# CORS_ORIGINS=https://juax-backend.vercel.app,http://localhost:8081,http://localhost:5080

# Mapbox (web console map + geocoding)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token

# M-Pesa Daraja (Phase 6 — server-side only, never in Expo)
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_PASSKEY=
# MPESA_SHORTCODE=
# MPESA_CALLBACK_URL=
