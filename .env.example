# Copy to .env and fill in — never commit .env
#
# ── Local dev (direct Aiven — no pooler needed for one process) ─────────────
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/defaultdb?sslmode=require
DIRECT_URL=postgres://USER:PASSWORD@HOST:PORT/defaultdb?sslmode=require
#
# ── Vercel WITHOUT Aiven pooler (free/hobby tier) ─────────────────────────
# Option A — Prisma Accelerate (recommended, free ~60k ops/mo):
#   1. https://console.prisma.io → create project → connect your Aiven URL
#   2. On Vercel:
#        DATABASE_URL=prisma://accelerate.prisma-data.net/?api_key=…
#        DIRECT_URL=postgres://…direct aiven…?sslmode=require
# Option B — Deploy API on Render/Railway instead of Vercel (single process)
# Option C — Upgrade Aiven to Startup+ for built-in connection pool URL
#
# ── Vercel WITH Aiven pooler (Startup plan+) ───────────────────────────────
# DATABASE_URL=<Aiven pooler URL>?sslmode=require
# DIRECT_URL=<Aiven direct URL>?sslmode=require
# DATABASE_USE_PGBOUNCER=true
# PRISMA_CONNECTION_LIMIT=1

# Next.js — do not set NODE_ENV here; Next sets it per command
PORT=5080

# Auth (Phase 1)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
# Show OTP in API responses until SMS is integrated (default: true when NODE_ENV !== production)
OTP_DEV_MODE=true
# One-click Admin/Agent/User sign-in on /login (defaults to same as OTP_DEV_MODE)
DEV_LOGIN_ENABLED=true

# CORS — browser / Expo Web only (native Expo fetch ignores CORS)
# Local dev:
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081,http://localhost:5080
# Vercel production example (replace with your deployment URL):
# CORS_ORIGINS=https://juax-backend.vercel.app,http://localhost:8081,http://localhost:5080

# Mapbox (web console map + geocoding)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token

# Simulated M-Pesa confirm endpoints until Daraja STK ships (default: on in dev, off in production)
PAYMENT_DEV_MODE=true

# M-Pesa Daraja (Phase 6 — server-side only, never in Expo)
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_PASSKEY=
# MPESA_SHORTCODE=
# MPESA_CALLBACK_URL=
